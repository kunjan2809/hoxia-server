# ========================
# DATABASE
# ========================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hoxia"

# ========================
# SERVER
# ========================
NODE_ENV=development
PORT=3000
BACKEND_URL=http://localhost:3000

# ========================
# CLIENT
# ========================
FRONTEND_URL=http://localhost:5173

# ========================
# CORS
# ========================
# Provide one or more allowed origins as a comma-separated list (no spaces needed, no surrounding quotes).
# Example: http://localhost:3000,http://localhost:5173,https://your-production-domain.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ========================
# JWT CONFIGURATION
# ========================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ========================
# COOKIES
# ========================
# Set to true if you need cookies over HTTP (local only). Never enable in production.
ALLOW_INSECURE_COOKIES=true
# COOKIE_DOMAIN=localhost

# ========================
# LOGGING
# ========================
# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=DEBUG

# ========================
# RATE LIMITING
# ========================
# Auth: max requests per IP per window (magic-link request, refresh, etc.)
# Values in milliseconds for window; integer for max. Omit to use defaults.
# RATE_LIMIT_AUTH_WINDOW_MS=60000
# RATE_LIMIT_AUTH_MAX=10

# ========================
# AUTH (Magic Link)
# ========================
MAGIC_LINK_EXPIRES_IN_MINUTES=15
BCRYPT_SALT_ROUNDS=12

# ========================
# EMAIL (Resend)
# ========================
# When MAIL_ENABLED=false:
# - In development: the magic link will be logged (so you can copy it)
# - In production: nothing is logged
MAIL_ENABLED=false
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=no-reply@your-domain.com
RESEND_FROM_NAME=Hoxia

